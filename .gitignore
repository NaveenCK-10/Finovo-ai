# ══════════════════════════════════════════════
#  Finovo AI — .gitignore
#  React (Vite) + Node.js + Firebase monorepo
# ══════════════════════════════════════════════

# ── Dependencies ──────────────────────────────
node_modules/
frontend/node_modules/
backend/node_modules/
.pnp
.pnp.js

# ── Environment Variables (NEVER commit) ──────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
frontend/.env
frontend/.env.local
frontend/.env.development
frontend/.env.production
backend/.env
backend/.env.local
backend/.env.development
backend/.env.production

# ── Build Output ──────────────────────────────
dist/
build/
frontend/dist/
frontend/build/
backend/dist/
backend/build/
.vite/
frontend/.vite/

# ── Firebase ──────────────────────────────────
.firebase/
firebase-debug.log
firebase-debug.*.log
.firebaserc.local
firestore-debug.log
ui-debug.log
database-debug.log

# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Runtime & Cache ───────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo
frontend/.tsbuildinfo

# ── OS Files ──────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / Editor ──────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── Testing ───────────────────────────────────
coverage/
frontend/coverage/
backend/coverage/
.nyc_output/

# ── Misc ──────────────────────────────────────
*.local
*.pem
*.key
*.cert
