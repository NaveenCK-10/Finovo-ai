<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0ea5e9;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1e1b4b;stop-opacity:1" />
    </linearGradient>
    <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="4" result="blur" />
      <feComposite in="SourceGraphic" in2="blur" operator="over" />
    </filter>
  </defs>
  <rect width="100" height="100" rx="20" fill="url(#grad1)" />
  <circle cx="50" cy="50" r="35" fill="none" stroke="#6366f1" stroke-width="4" filter="url(#glow)" />
  <path d="M 30,60 L 45,40 L 60,50 L 75,30 M 75,30 L 75,40 M 75,30 L 65,30" fill="none" stroke="#22d3ee" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
  <text x="50" y="80" fill="#ffffff" font-family="sans-serif" font-size="18" font-weight="bold" text-anchor="middle" filter="url(#glow)">₹</text>
</svg>
