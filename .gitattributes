# ══════════════════════════════════════════════
#  Finovo AI — .gitattributes
#  Normalizes line endings (LF/CRLF) across platforms
# ══════════════════════════════════════════════

# Default: auto-detect text files and normalize to LF in repo
* text=auto

# Explicitly LF for source files
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.env   text eol=lf
*.rules text eol=lf

# Binary files — no line-ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.webp  binary
*.mp4   binary
*.zip   binary
